    CONTROL         "",IDC_STATIC_DOWN,"Static",SS_BLACKFRAME | SS_SUNKEN,0,243,465,1
    PUSHBUTTON      "< Back",IDC_BACK,301,248,51,15
    DEFPUSHBUTTON   "Next >",IDC_NEXT,353,248,51,15
